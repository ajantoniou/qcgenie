{
  "name": "QC Genie",
  "description": "Pre-publish video QC for YouTube creators, studios, agencies, and agent workflows.",
  "api_base_url": "https://api.qcgenie.com/v1",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "format": "Bearer qcg_live_..."
  },
  "tools": [
    "qc_run_video",
    "qc_get_job",
    "qc_get_report",
    "qc_list_recent_jobs",
    "qc_create_upload_url"
  ],
  "primary_endpoints": [
    "POST /v1/qc/jobs",
    "GET /v1/qc/jobs/{job_id}",
    "GET /v1/qc/jobs/{job_id}/report",
    "POST /v1/uploads"
  ]
}
