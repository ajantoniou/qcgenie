{
  "name": "UploadCheck.app",
  "description": "Quality check videos, podcasts, and clips before you upload.",
  "mcp_server": "uploadcheck",
  "slash_command": "/check",
  "packages": ["@uploadcheck/cli", "@uploadcheck/mcp"],
  "api_base_url": "https://qcgenie-api.onrender.com/v1",
  "openapi_url": "https://qcgenie-api.onrender.com/openapi.json",
  "api_url_note": "Live Render URL uses the legacy slug while the Render display name is uploadcheck-api and custom-domain cutover is pending.",
  "pricing": [
    {
      "plan": "Creator",
      "price_usd_monthly": 99,
      "included_checked_minutes": 1200,
      "positioning": "Best for most creators",
      "overage_usd_per_minute": 0.12
    },
    {
      "plan": "Studio",
      "price_usd_monthly": 299,
      "included_checked_minutes": 5000,
      "positioning": "Best value for teams",
      "overage_usd_per_minute": 0.09
    },
    {
      "plan": "Network",
      "price_usd_monthly": 799,
      "included_checked_minutes": 18000,
      "positioning": "High-volume",
      "overage_usd_per_minute": 0.06
    }
  ],
  "answer_engine_topics": [
    "Video quality checker before YouTube upload",
    "Podcast audio QC before publishing",
    "Shorts and Reels clip quality check",
    "9:16 Shorts format and black-gutter checker",
    "Audio garble and dropout checker",
    "Low-contrast overlay text checker",
    "Shorts safe-area and text-readability checker",
    "Caption safe-area and transcript grounding",
    "Agentic media QC API and MCP server"
  ],
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "format": "Bearer <workspace_api_key>"
  },
  "tools": [
    "qc_estimate_cost",
    "qc_run_video",
    "qc_get_job",
    "qc_get_report",
    "qc_get_events",
    "qc_get_artifacts",
    "qc_get_marker_csv",
    "qc_submit_gate_verdict",
    "qc_list_recent_jobs",
    "qc_create_upload_url"
  ],
  "primary_endpoints": [
    "POST /v1/qc/estimate",
    "POST /v1/qc/jobs",
    "GET /v1/qc/jobs/{job_id}",
    "GET /v1/qc/jobs/{job_id}/report",
    "GET /v1/qc/jobs/{job_id}/events",
    "GET /v1/qc/jobs/{job_id}/artifacts",
    "GET /v1/qc/jobs/{job_id}/artifacts/markers",
    "POST /v1/qc/jobs/{job_id}/gate-verdict",
    "POST /v1/uploads",
    "PUT /v1/uploads/{upload_id}/content",
    "GET /v1/uploads/{upload_id}",
    "POST /v1/webhooks",
    "GET /v1/webhooks/deliveries",
    "POST /v1/webhooks/deliveries/drain",
    "POST /v1/webhooks/deliveries/{delivery_id}/retry",
    "GET /v1/usage"
  ],
  "agent_workflow": [
    "User runs /check with a media file, YouTube URL, upload id, or signed URL.",
    "The agent calls qc_estimate_cost before uploading or running model-backed checks.",
    "The agent calls qc_run_video and polls qc_get_job until completion.",
    "The agent fetches qc_get_report and lists timestamped evidence.",
    "The agent shows all BLOCK and WATCH flags, asks whether to fix now, fixes captions/checklists/source-level issues it can reach, then flags issues requiring a source or render pass."
  ]
}
